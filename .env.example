# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/pricemonitor

# Redis
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_redis_password

# Feishu Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN_HERE

# JD Cookie (full session cookies)
JD_COOKIE=your_jd_cookie_here

# CDP endpoints must be localhost by default. Set true only inside a private network.
CDP_ALLOW_NON_LOCAL=false

# Crawler settings
DATA_RETENTION_DAYS=365
# Product/profile browser debug switch. Keep true in normal runs; set false locally to watch Playwright.
CRAWLER_HEADLESS=true
# Product crawl fan-out inside one worker task. Must be >=1; keep low for anti-bot safety.
PRODUCT_CRAWL_CONCURRENCY=1

# Proxy settings (optional)
# CRAWL_PROXY_URL=http://user:pass@host:port
# CRAWL_PROXY_ENABLED=false

# CDP mode: connect to existing browser with JD login session
CDP_ENABLED=false
CDP_URL=http://127.0.0.1:9222

# Boss/51job job crawl uses a logged-in CloakBrowser profile at profiles/default/.
# Create additional profiles at profiles/{key} and pass profile_dir to the adapter.
# Runtime progress logs are written to backend/logs/.

# App settings
APP_NAME=Price Monitor
DEBUG=false
# Keep false for normal local runs. Set true only when you explicitly want SQLAlchemy SQL logs.
DATABASE_ECHO=false
# Comma-separated or JSON list. Must include the Vite console and public blog origins used by browser clients.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Public blog
BLOG_PUBLIC_BASE_URL=http://localhost:3001
BLOG_MEDIA_ROOT=uploads/blog
BLOG_MEDIA_PUBLIC_PREFIX=/blog-media
BLOG_MEDIA_MAX_BYTES=8388608
# Optional Next.js blog runtime overrides.
BLOG_API_BASE_URL=http://127.0.0.1:8000/v1
BLOG_BACKEND_ORIGIN=http://127.0.0.1:8000
NEXT_PUBLIC_BLOG_BASE_URL=http://localhost:3001

# Job match LLM
JOB_MATCH_PROVIDER=minimax
JOB_MATCH_MODEL=MiniMax-M2.7
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_API_KEY=your_minimax_api_key_here

# JWT settings (MUST be changed from default)
JWT_SECRET_KEY=change-this-to-a-random-secret-key
